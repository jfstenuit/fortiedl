# ============================================================
# Blocklist Manager — environment configuration
# Copy this file to .env and fill in all values before running.
# ============================================================

# ── OIDC (Azure AD / Authentik / Okta / Keycloak) ──────────
OIDC_DISCOVERY_URL=https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
OIDC_CLIENT_ID=<app-registration-client-id>
OIDC_CLIENT_SECRET=<app-registration-client-secret>
OIDC_REDIRECT_URI=https://blocklist.example.com/auth/callback
# Optional: only this group (display name) may access the app
OIDC_REQUIRED_GROUP=Firewall-Admins

# ── Session ──────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE-ME-generate-a-random-secret

# ── EDL Basic Auth (used by the firewall to fetch lists) ─────
LIST_BASIC_AUTH_USER=edl
LIST_BASIC_AUTH_PASSWORD=CHANGE-ME-strong-password

# ── Database ─────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=blocklist
DB_USER=blocklist
DB_PASSWORD=CHANGE-ME-strong-db-password

# ── Application ──────────────────────────────────────────────
APP_PORT=8080
APP_LOG_LEVEL=INFO
GUNICORN_WORKERS=2

# ── Lists ────────────────────────────────────────────────────
DEFAULT_LIST=default
